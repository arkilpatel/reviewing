% ===============================================================
% v1paper.sty — Single-column arXiv preprint style
% Inspired by berkeley.sty single-column format
% ===============================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{v1paper}[2025/07/01 V1 Paper Single-Column Style]

% ---------------------------------------------------------------
% Page geometry
% ---------------------------------------------------------------
\RequirePackage[margin=1in]{geometry}

% ---------------------------------------------------------------
% Force single-column mode
% ---------------------------------------------------------------
\renewcommand{\twocolumn}[1][]{#1}
\AtBeginDocument{\onecolumn}

% ---------------------------------------------------------------
% Fonts (TeX Gyre Pagella)
% ---------------------------------------------------------------
\RequirePackage[T1]{fontenc}
\usepackage{tgpagella}

\AtBeginDocument{%
  \renewcommand{\rmdefault}{qpl}%
  \renewcommand{\familydefault}{\rmdefault}%
  \normalfont
}

\newcommand{\titleFont}{\bfseries\fontfamily{qpl}\selectfont}
\newcommand{\authorFont}{\fontfamily{qpl}\selectfont}

% ---------------------------------------------------------------
% Colors + box styling
% ---------------------------------------------------------------
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins, breakable}
\RequirePackage{ragged2e}
\RequirePackage{setspace}

% Light pastel lavender for abstract box
\definecolor{abstractbg}{RGB}{244,246,254}
\definecolor{abstractborder}{RGB}{255,255,255}
\definecolor{titleblue}{HTML}{1a2a6c}

\tcbset{
  abstractbox/.style={
    enhanced,
    breakable,
    colback=abstractbg,
    colframe=abstractborder,
    boxrule=0pt,
    arc=12pt,
    left=0.6cm,
    right=0.6cm,
    top=0.6cm,
    bottom=1.2cm,
    overlay={
      \node[anchor=south east, inner sep=0pt] at ([xshift=-0.5cm,yshift=0.5cm]frame.south east)
        {\includegraphics[height=1.3cm]{BAIR_Logo.png}};
    },
  }
}

% ---------------------------------------------------------------
% Hyperlinks
% ---------------------------------------------------------------
\RequirePackage[
    pagebackref,
    breaklinks,
    colorlinks,
    linkcolor=titleblue,
    citecolor=titleblue,
    urlcolor=titleblue,
    filecolor=titleblue
]{hyperref}

% ---------------------------------------------------------------
% Override abstract environment (will be used inside maketitle box)
% ---------------------------------------------------------------
\let\v@abstract\relax
\newcommand{\v@abstracttext}{}
\renewenvironment{abstract}{%
  \long\gdef\v@abstracttext
}{%
}

% ---------------------------------------------------------------
% Title, author storage
% ---------------------------------------------------------------
% We use standard \title and \author

% ---------------------------------------------------------------
% Custom maketitle
% ---------------------------------------------------------------
\let\orig@maketitle\maketitle

\renewcommand{\maketitle}{%
  \begingroup
  \renewcommand{\thefootnote}{}%
  \begin{tcolorbox}[abstractbox, width=\textwidth]
      \raggedright
      % Title
      {\LARGE\titleFont \textcolor{titleblue}{\@title}\par}
      \vspace{0.5em}
      % Authors
      {\large\authorFont \@author\par}
      % Abstract
      \vspace{0.5em}
      \begingroup
      \authorFont
      \setstretch{1.1}
      \justifying
      \v@abstracttext
      \endgroup
  \end{tcolorbox}
  \vspace{1.5em}
  \endgroup
}

% ---------------------------------------------------------------
% Paragraph formatting
% ---------------------------------------------------------------
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.6em}

% ---------------------------------------------------------------
% Page style
% ---------------------------------------------------------------
\AtBeginDocument{
  \pagestyle{plain}
  \pagenumbering{arabic}
}

% ---------------------------------------------------------------
% Section formatting - slightly larger for single-column
% ---------------------------------------------------------------
\RequirePackage{titlesec}
\titleformat{\section}{\Large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\large\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\bfseries}{\thesubsubsection}{1em}{}

\endinput
