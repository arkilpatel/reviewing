}

\foreach \i/\y in {1/2.5,2/1.25,3/0.0}{
  \node[neuron] (hA\i) at (\xhA,\y) {$B_?$};
}

\draw[worange] (in1.east) -- (hA1);
\draw[worange] (in2.east) -- (hA1);
\draw[wgreen] (in3.east) -- (hA1);
