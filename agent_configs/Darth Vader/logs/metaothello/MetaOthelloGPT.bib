	keywords = {Computer Science - Machine Learning, Computer Science - Artificial Intelligence},
	file = {Preprint PDF:/Users/ejhall2/Zotero/storage/L5SX9JEY/Ainsworth et al. - 2023 - Git Re-Basin Merging Models modulo Permutation Symmetries.pdf:application/pdf;Snapshot:/Users/ejhall2/Zotero/storage/8ZEAMFNG/2209.html:text/html},
