	file = {Full Text PDF:/Users/ejhall2/Zotero/storage/ZXE43HG4/Yun et al. - 2023 - Emergence of Abstract State Representations in Embodied Sequence Modeling.pdf:application/pdf},
}

@inproceedings{wang_can_2024,
	title = {Can {Language} {Models} {Serve} as {Text}-{Based} {World} {Simulators}?},
