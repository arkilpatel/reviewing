	keywords = {Computer Science - Computation and Language, Computer Science - Machine Learning, Computer Science - Artificial Intelligence},
	file = {Full Text PDF:/Users/ejhall2/Zotero/storage/DAF9CKSA/Wu et al. - 2024 - ReFT Representation Finetuning for Language Models.pdf:application/pdf;Snapshot:/Users/ejhall2/Zotero/storage/5UNCKB3T/2404.html:text/html},
}

