@article{doi:10.1126/sciadv.abi6070,
author = {Lea-Maria Schmitt  and Julia Erb  and Sarah Tune  and Anna U. Rysop  and Gesa Hartwigsen  and Jonas Obleser },
title = {Predicting speech from a cortical hierarchy of event-based time scales},
journal = {Science Advances},
volume = {7},
number = {49},
pages = {eabi6070},
year = {2021},
doi = {10.1126/sciadv.abi6070},
eprint = {https://www.science.org/doi/pdf/10.1126/sciadv.abi6070}
,
    abstract = { A temporoparietal pathway structures human speech into hierarchically organized events to make predictions on upcoming words. How do predictions in the brain incorporate the temporal unfolding of context in our natural environment? We here provide evidence for a neural coding scheme that sparsely updates contextual representations at the boundary of events. This yields a hierarchical, multilayered organization of predictive language comprehension. Training artificial neural networks to predict the next word in a story at five stacked time scales and then using model-based functional magnetic resonance imaging, we observe an event-based “surprisal hierarchy” evolving along a temporoparietal pathway. Along this hierarchy, surprisal at any given time scale gated bottom-up and top-down connectivity to neighboring time scales. In contrast, surprisal derived from continuously updated context influenced temporoparietal activity only at short time scales. Representing context in the form of increasingly coarse events constitutes a network architecture for making predictions that is both computationally efficient and contextually diverse. }
}

